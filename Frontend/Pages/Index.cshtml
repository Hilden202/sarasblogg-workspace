@page
@using Extensions
@model IndexModel
@{
    ViewData["Title"] = "Hem";
}

<div class="header-container">
    <div class="left-side">
        <h1 class="header-title">
            <a asp-area="" asp-page="/Index">
                <img class="logo-img" src="~/img/logo/logga.png" alt="med hjärtat som kompass logotype" />
            </a>
        </h1>
    </div>
</div>

<div class="spotify-section">
    <div class="spotify-box"
         data-spotify-carousel
         data-spotify-embeds="https://open.spotify.com/embed/album/4qQjC0R00dOaZm2bxfPnTn?utm_source=generator|https://open.spotify.com/embed/album/3rsAvZCJIOiBzrSshIg7qr?utm_source=generator|https://open.spotify.com/embed/album/0nmtLZ1GkySVEaKjey0zY4?utm_source=generator|https://open.spotify.com/embed/album/50PdYSstjgW7qoP7aOzsDs?utm_source=generator"
         aria-label="Spotify-spelare">
        <iframe
            class="spotify-section__frame"
            style="border-radius:12px"
            src="https://open.spotify.com/embed/album/4qQjC0R00dOaZm2bxfPnTn?utm_source=generator"
            width="320"
            height="80"
            frameborder="0"
            allowfullscreen
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy">
        </iframe>
        <div class="spotify-section__controls" aria-label="Byt låt">
            <button type="button" class="spotify-section__nav" data-spotify-prev aria-label="Föregående låt">‹</button>
            <div class="spotify-section__dots" aria-hidden="true">
                <button type="button" class="spotify-section__dot is-active" data-spotify-dot data-index="0" aria-label="Visa låt 1"></button>
                <button type="button" class="spotify-section__dot" data-spotify-dot data-index="1" aria-label="Visa låt 2"></button>
                <button type="button" class="spotify-section__dot" data-spotify-dot data-index="2" aria-label="Visa låt 3"></button>
                <button type="button" class="spotify-section__dot" data-spotify-dot data-index="3" aria-label="Visa låt 4"></button>
            </div>
            <button type="button" class="spotify-section__nav" data-spotify-next aria-label="Nästa låt">›</button>
        </div>
    </div>
</div>

<div class="content-container d-flex mt-4">
    <div class="blog-posts flex-grow-1 me-3">
        @await Html.PartialAsync("Shared/_LatestPosts", Model.LatestPosts)
    </div>

    <div class="om-mig-box">
        <a asp-page="/AboutMe" class="text-decoration-none aboutme-link">
            @if (Model.AboutMe != null && !string.IsNullOrEmpty(Model.AboutMe.Image))
            {
                <div class="aboutme-wrapper">
                    <img class="aboutme-img"
                         src="@(string.IsNullOrWhiteSpace(Model.AboutMe.Image) ? "/img/blogg/default.png" : Model.AboutMe.Image)"
                         onerror="this.onerror=null; this.src='/img/blogg/default.png';"
                         alt="Om Mig-bild" />
                    <div>
                        <h3 class="blogg-title">@Model.AboutMe.Title</h3>
                        <div class="blogg-content prose">
                            <div class="preview-inner preview-clamp">
                                @Html.Raw(Model.AboutMe.Content)
                            </div>
                            <span class="readmore-link">Läs mer</span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <p>Om mig-sektionen är ännu inte skapad.</p>
            }
        </a>
    </div>
</div>
