@model SarasBlogg.Models.AboutMe

@if (Model != null)
{
    <div class="card om-mig-card">

        <!-- Profilbild (rund, centrerad) -->
        @if (!string.IsNullOrWhiteSpace(Model.Image))
        {
            <div class="aboutme-header text-center mt-3">
                <img class="aboutme-img"
                     src="@(string.IsNullOrWhiteSpace(Model.Image) ? "/img/blogg/default.png" : Model.Image)"
                     onerror="this.onerror=null; this.src='/img/blogg/default.png';"
                     alt="Om Mig-bild" />
            </div>
        }

        <!-- Titel (visa endast om finns, undviker tom spacing) -->
        @if (!string.IsNullOrWhiteSpace(Model.Title))
        {
            <h4 class="card-title text-center px-3 mt-3">
                @Model.Title
            </h4>
        }

        <!-- Content (TinyMCE-styrd färg) -->
        <div class="card-content prose preview-clamp px-3 mt-2">
            @Html.Raw(Model.Content)
        </div>

        <!-- Footer -->
        <div class="card-footer">
            <span class="readmore-link">Läs mer…</span>
        </div>

    </div>
}