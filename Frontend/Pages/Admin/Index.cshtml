@page
@using System.Text.Json
@model SarasBlogg.Pages.Admin.IndexModel
@{
	var todaySE = DateTime.UtcNow.ToSwedishTime().Date;
}

<div class="container-site">
	@if (Model.IsAdmin || Model.IsSuperAdmin || Model.IsSuperUser)
	{
		<partial name="/Pages/Admin/_AdminNav.cshtml" />

		<!-- LISTA PUBLICERADE BLOGGAR -->
		<h2>Lista Publicerade Bloggar</h2>
		@if (Model.BloggsWithImage != null && Model.BloggsWithImage.Any(b => !b.Blogg.Hidden))
		{
			<div class="table-responsive-lg">
				<table class="border table table-striped shadow-sm align-middle admin-table">
					<thead>
						<tr>
							<th class="text-center align-middle border d-none d-md-table-cell" colspan="3">Knappar</th>
							<th class="text-center align-middle border d-table-cell d-md-none" colspan="1">Knappar</th>
							<th class="text-center align-middle border">Id</th>
							<th class="text-center align-middle border">Titel</th>
							<th class="text-center align-middle border d-none d-md-table-cell">Innehåll</th>
							<th class="text-center align-middle border d-none d-md-table-cell">Författare</th>
							<th class="text-center align-middle border d-none d-md-table-cell">Lanserings Datum</th>
							<th class="text-center align-middle border d-none d-md-table-cell">Bild</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model.BloggsWithImage.Where(b => !b.Blogg.Hidden))
						{
							<tr>
								<td class="text-center align-middle d-none d-md-table-cell" colspan="3">
									<div class="admin-btn-group">
										@* Dölj/Visa + Arkivera: admin & superadmin. Superuser = disabled *@
										@if (Model.IsAdmin || Model.IsSuperAdmin)
										{
											<a asp-route-hiddenId="@item.Blogg.Id" class="btn btn-outline-warning">Dölj</a>
											@if (item.Blogg.IsArchived)
											{
												<a asp-route-archiveId="@item.Blogg.Id" class="btn btn-outline-warning ms-1">Arkiverad</a>
											}
											else
											{
												<a asp-route-archiveId="@item.Blogg.Id" class="btn btn-outline-success ms-1">Publicerad</a>
											}
										}
										else
										{
											<span class="btn btn-outline-secondary disabled">Dölj</span>
											<span class="btn btn-outline-secondary disabled ms-1">Status</span>
										}

										@* Ändra: endast superadmin *@
										@if (Model.IsSuperAdmin)
										{
											<button type="button" onclick="openEditor(@item.Blogg.Id)" class="btn btn-outline-primary ms-1">Ändra</button>
										}
									</div>
								</td>
								<td class="text-center align-middle d-table-cell d-md-none">
									<div class="d-flex flex-column gap-1">
										@if (Model.IsAdmin || Model.IsSuperAdmin)
										{
											<form method="get">
												<input type="hidden" name="hiddenId" value="@item.Blogg.Id" />
												<button type="submit" class="btn btn-outline-warning w-100">Dölj</button>

											</form>
											@if (item.Blogg.IsArchived)
											{
												<a asp-route-archiveId="@item.Blogg.Id" class="btn btn-outline-warning w-100">Arkiverad</a>
											}
											else
											{
												<a asp-route-archiveId="@item.Blogg.Id" class="btn btn-outline-success w-100">Publicerad</a>
											}
										}
										else
										{
											<span class="btn btn-outline-secondary disabled w-100">Dölj</span>
											<span class="btn btn-outline-secondary disabled w-100">Status</span>
										}

										@if (Model.IsSuperAdmin)
										{
											<button type="button" onclick="openEditor(@item.Blogg.Id)" class="btn btn-outline-primary w-100">Ändra</button>
										}
									</div>
								</td>
								<td class="text-center align-middle border">@item.Blogg.Id</td>
								<td class="text-lg-start align-middle border title-cell">
									@item.Blogg.Title
									<div class="d-md-none small text-muted mt-1">
										Förf: @item.Blogg.Author •
										@{
											var launchDateClass = item.Blogg.LaunchDate.ToSwedishTime().Date > todaySE ? "text-warning" : "text-success";
										}
										<span class="@launchDateClass">
											@item.Blogg.LaunchDate.ToSwedishTime().ToString("yyyy-MM-dd")
										</span>
									</div>
									@{
										var imageUrl_m = item.FirstImage?.FilePath;
										var isExternal_m = !string.IsNullOrEmpty(imageUrl_m) &&
										(imageUrl_m.StartsWith("http://") || imageUrl_m.StartsWith("https://"));
									}
									@if (!string.IsNullOrWhiteSpace(imageUrl_m))
									{
										<div class="d-md-none mt-1">
											<img class="image-inline" src="@(isExternal_m ? imageUrl_m : Url.Content(imageUrl_m))"
												 onerror="this.onerror=null; this.src='/img/blogg/default.png';" alt="Förhandsbild" />
										</div>
									}
								</td>
								<td class="text-lg-start align-middle border d-none d-md-table-cell">
									@Html.Raw(item.Blogg.Content?.LimitLength(100, true))</td>
									<td class="text-center align-middle border d-none d-md-table-cell">@item.Blogg.Author</td>
									<td class="text-center align-middle border d-none d-md-table-cell">
										@{
											var launchDateClassDesktop = item.Blogg.LaunchDate.ToSwedishTime().Date > todaySE ?
							"text-warning" : "text-success";
										}
										<span class="@launchDateClassDesktop">
											@item.Blogg.LaunchDate.ToSwedishTime().ToString("yyyy-MM-dd")
										</span>
									</td>
									<td class="text-center align-middle border image-column d-none d-md-table-cell">
										@{
											var imageUrl = item.FirstImage?.FilePath;
											var isExternal = !string.IsNullOrEmpty(imageUrl) &&
											(imageUrl.StartsWith("http://") || imageUrl.StartsWith("https://"));
										}
										<img class="admin-blog-img"
											 src="@(isExternal ? imageUrl : Url.Content(imageUrl ?? "/img/blogg/default.png"))"
											 onerror="this.onerror=null; this.src='/img/blogg/default.png';" alt="Förhandsbild" />
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
		else
			{
				<p>Ingen blogg finns att visa.</p>
			}


			<!-- LISTA DOLDA BLOGGAR -->
			<h2>Lista Dolda Bloggar</h2>
			@if (Model.BloggsWithImage != null && Model.BloggsWithImage.Any(b => b.Blogg.Hidden))
			{
				<div class="table-responsive-lg">
					<table class="border table table-striped shadow-sm align-middle admin-table">
						<thead>
							<tr>
								<th class="text-center align-middle border d-none d-md-table-cell" colspan="3">Knappar</th>
								<th class="text-center align-middle border d-table-cell d-md-none" colspan="1">Knappar</th>
								<th class="text-center align-middle border">Id</th>
								<th class="text-center align-middle border">Titel</th>
								<th class="text-center align-middle border d-none d-md-table-cell">Innehåll</th>
								<th class="text-center align-middle border d-none d-md-table-cell">Författare</th>
								<th class="text-center align-middle border d-none d-md-table-cell">Lanserings Datum</th>
								<th class="text-center align-middle border d-none d-md-table-cell">Bild</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var item in Model.BloggsWithImage.Where(b => b.Blogg.Hidden))
							{
								<tr>
									<td class="text-center align-middle d-none d-md-table-cell" colspan="3">
										<div class="admin-btn-group">
											@* Ta bort: endast superadmin *@
											@if (Model.IsSuperAdmin)
											{
												<form method="post" asp-page-handler="DeleteBlogg"
													  onsubmit="return handleDeleteSubmit(event, this)"
													  data-confirm="Ta bort inlägget ”@item.Blogg.Title” permanent?">
													@Html.AntiForgeryToken()
													<input type="hidden" name="deleteId" value="@item.Blogg.Id" />
													<button type="submit" class="btn btn-outline-danger">Ta bort</button>
												</form>


											}
											else
											{
												<span class="btn btn-outline-secondary disabled me-1">Ta bort</span>
											}

											@* Visa (av-dölj): admin + superadmin. Superuser = disabled *@
											@if (Model.IsAdmin || Model.IsSuperAdmin)
											{
												<a asp-route-hiddenId="@item.Blogg.Id" class="btn btn-outline-success">Visa</a>
											}
											else
											{
												<span class="btn btn-outline-secondary disabled">Visa</span>
											}

											@* Ändra: endast superadmin *@
											@if (Model.IsSuperAdmin)
											{
												<button type="button" onclick="openEditor(@item.Blogg.Id)" class="btn btn-outline-primary">Ändra</button>
											}
										</div>
									</td>
									<td class="text-center align-middle d-table-cell d-md-none">
										<div class="d-flex flex-column gap-1">
											@if (Model.IsSuperAdmin)
											{
												<form method="post" asp-page-handler="DeleteBlogg"
													  onsubmit="return handleDeleteSubmit(event, this)"
													  data-confirm="Ta bort inlägget ”@item.Blogg.Title”?">
													@Html.AntiForgeryToken()
													<input type="hidden" name="deleteId" value="@item.Blogg.Id" />
													<button type="submit" class="btn btn-outline-danger w-100">Ta bort</button>
												</form>
											}
											else
											{
												<span class="btn btn-outline-secondary disabled w-100">Ta bort</span>
											}

											@if (Model.IsAdmin || Model.IsSuperAdmin)
											{
												<a asp-route-hiddenId="@item.Blogg.Id" class="btn btn-outline-success w-100">Visa</a>
											}
											else
											{
												<span class="btn btn-outline-secondary disabled w-100">Visa</span>
											}

											@if (Model.IsSuperAdmin)
											{
												<button type="button" onclick="openEditor(@item.Blogg.Id)" class="btn btn-outline-primary w-100">Ändra</button>
											}
										</div>
									</td>
									<td class="text-center align-middle border">@item.Blogg.Id</td>
									<td class="text-lg-start align-middle border title-cell">
										@item.Blogg.Title
										<div class="d-md-none small text-muted mt-1">
											Förf: @item.Blogg.Author •
											@{
												var hiddenLaunchDateClass = item.Blogg.LaunchDate.ToSwedishTime().Date > todaySE ?
								"text-warning" : "text-success";
											}
											<span class="@hiddenLaunchDateClass">
												@item.Blogg.LaunchDate.ToSwedishTime().ToString("yyyy-MM-dd")
											</span>
										</div>
										@{
											var imageUrl_m = item.FirstImage?.FilePath;
											var isExternal_m = !string.IsNullOrEmpty(imageUrl_m) &&
											(imageUrl_m.StartsWith("http://") || imageUrl_m.StartsWith("https://"));
										}
										@if (!string.IsNullOrWhiteSpace(imageUrl_m))
										{
											<div class="d-md-none mt-1">
												<img class="image-inline" src="@(isExternal_m ? imageUrl_m : Url.Content(imageUrl_m))"
													 onerror="this.onerror=null; this.src='/img/blogg/default.png';" alt="Förhandsbild" />
											</div>
										}
									</td>
									<td class="text-lg-start align-middle border d-none d-md-table-cell">
										@Html.Raw(item.Blogg.Content?.LimitLength(100, true))</td>
										<td class="text-center align-middle border d-none d-md-table-cell">@item.Blogg.Author</td>
										<td class="text-center align-middle border d-none d-md-table-cell">
											@{
												var hiddenLaunchDateClassDesktop = item.Blogg.LaunchDate.ToSwedishTime().Date > todaySE ?
								"text-warning" : "text-success";
											}
											<span class="@hiddenLaunchDateClassDesktop">
												@item.Blogg.LaunchDate.ToSwedishTime().ToString("yyyy-MM-dd")
											</span>
										</td>
										<td class="text-center align-middle border image-column d-none d-md-table-cell">
											@{
												var imageUrl = item.FirstImage?.FilePath;
												var isExternal = !string.IsNullOrEmpty(imageUrl) &&
												(imageUrl.StartsWith("http://") || imageUrl.StartsWith("https://"));
											}
											<img class="admin-blog-img"
												 src="@(isExternal ? imageUrl : Url.Content(imageUrl ?? "/img/blogg/default.png"))"
												 onerror="this.onerror=null; this.src='/img/blogg/default.png';" alt="Förhandsbild" />
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
		else
				{
					<p>Ingen dold blogg finns att visa.</p>
				}
			}
			else
			{
				<p class="text-danger">Du måste vara inloggad för att komma åt denna sida.</p>
			}
		</div>

@if (Model.IsSuperAdmin)
{
	@await Html.PartialAsync("_BloggEditorModal", new SarasBlogg.ViewModels.BloggEditorModalModel {
		EditorAccessToken     = Model.EditorAccessToken,
		EditedBloggWithImages = null,
		NewBlogg              = new SarasBlogg.Models.Blogg()
	})

	<script>
		const bloggListData = @Html.Raw(JsonSerializer.Serialize(
			(Model.BloggsWithImage ?? new List<BloggWithImage>()).Select(b => new {
				id         = b.Blogg.Id,
				title      = b.Blogg.Title,
				content    = b.Blogg.Content,
				author     = b.Blogg.Author,
				launchDate = b.Blogg.LaunchDate.ToSwedishTime().ToString("yyyy-MM-dd"),
				userId     = b.Blogg.UserId
			}),
			new JsonSerializerOptions { Encoder = System.Text.Encodings.Web.JavaScriptEncoder.Default }
		));
		const currentBloggData = null;
	</script>
}

@section Scripts {
	@if (Model.IsSuperAdmin)
	{
		<script src="~/lib/tinymce/tinymce.min.js"></script>
		<script src="~/js/blogg-editor.js"></script>
		<script src="~/js/tinymce-config.admin.v3.js"></script>
	}
}
